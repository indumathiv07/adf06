{
	"name": "DS_sqltable_Parquet",
	"properties": {
		"linkedServiceName": {
			"referenceName": "lS_sqltable_Parquet",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Tablename": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat(dataset().Tablename,'_',formatDateTime(utcNow(),'yyyyMMddHHmmss'),'.parquet')",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat(dataset().Tablename,'/',formatDateTime(utcNow(),'yyyy/MM/dd'))",
					"type": "Expression"
				},
				"fileSystem": "outputmiragrationpr"
			},
			"compressionCodec": "none"
		},
		"schema": []
	}
}